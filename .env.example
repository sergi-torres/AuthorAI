# AutorIA — environment template.
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — NEVER commit real secrets.
#
# On the deploy platforms these same keys are set in the dashboards, not here:
#   - Frontend (Vercel):  Project → Settings → Environment Variables
#   - Backend  (Railway): Service → Variables
# Verify the backend picked them up with:  GET /internal/env-check

# ─── Database (Supabase Postgres, pooled connection) ───
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── IBM Watsonx (AI generation) ───
# Required. WATSONX_URL / PROJECT_ID are also needed for real generation calls.
WATSONX_API_KEY=
WATSONX_URL="https://us-south.ml.cloud.ibm.com"
WATSONX_PROJECT_ID=

# ─── Supabase (DB REST + vector store) ───
# Required. SUPABASE_KEY: use the service_role key on the backend (server-side
# only), or the anon key if you rely solely on Row Level Security.
SUPABASE_URL=
SUPABASE_KEY=

# ─── Backend runtime ───
# Comma-separated list of allowed CORS origins. Add your Vercel URL in prod,
# e.g. "http://localhost:3000,https://autoria.vercel.app"
AUTORIA_CORS_ORIGINS="http://localhost:3000"

# ─── Frontend (Vercel) ───
# Only NEXT_PUBLIC_-prefixed vars are exposed to the browser. Point this at the
# Railway backend URL in prod, e.g. "https://autoria-api.up.railway.app"
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"

# ─── Authorship Passport (Sprint 2) ───
# Run `make keys` (scripts/generate_keys.py) to create keys/ — git-ignored.
PASSPORT_PRIVATE_KEY_PATH="keys/passport.priv.pem"
PASSPORT_PUBLIC_KEY_PATH="keys/passport.pub.pem"
PASSPORT_KID="autoria-2026-07"
PASSPORT_VERIFIER_URL="https://autoria.app/verify"
